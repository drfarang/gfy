{
  "name": "@paleproton/gfy",
  "version": "0.1.2",
  "description": "A terminal UI client for gfy.com (the GFY Webmaster Board vBulletin forum)",
  "author": "paleproton",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drfarang/gfy.git"
  },
  "homepage": "https://github.com/drfarang/gfy#readme",
  "bugs": {
    "url": "https://github.com/drfarang/gfy/issues"
  },
  "module": "src/index.tsx",
  "type": "module",
  "bin": {
    "gfy": "src/index.tsx"
  },
  "files": [
    "src",
    "tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "gfy",
    "vbulletin",
    "forum",
    "tui",
    "terminal",
    "opentui",
    "bun"
  ],
  "scripts": {
    "dev": "bun run src/index.tsx",
    "start": "bun run src/index.tsx",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "probe": "bun run scripts/probe.ts",
    "smoke": "bun run scripts/smoke-render.tsx",
    "prepublishOnly": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.17"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.4.1",
    "@opentui/react": "^0.4.1",
    "cheerio": "^1.0.0",
    "opentui-spinner": "^0.0.7",
    "react": "^19.2.6",
    "sharp": "^0.35.2"
  }
}
